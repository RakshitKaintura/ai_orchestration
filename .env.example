# ─── LLM Provider ────────────────────────────────────────────────────────────
# Anthropic Claude (primary LLM)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (used for embeddings: text-embedding-3-small)
OPENAI_API_KEY=your_openai_api_key_here

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=mega_ai
POSTGRES_USER=mega_ai_user
POSTGRES_PASSWORD=change_me_in_production

# Full DSN (constructed from the above; override if needed)
DATABASE_URL=postgresql://mega_ai_user:change_me_in_production@db:5432/mega_ai

# ─── Redis (Celery broker + result backend) ───────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_data
CHROMA_COLLECTION_NAME=mega_ai_corpus

# ─── Log UI ───────────────────────────────────────────────────────────────────
LOG_UI_HOST=0.0.0.0
LOG_UI_PORT=8080

# ─── Evaluation ───────────────────────────────────────────────────────────────
# Set to "true" to auto-trigger eval after each pipeline run (dev only)
AUTO_EVAL=false

# ─── Context Budget Defaults (tokens) ────────────────────────────────────────
DECOMPOSITION_BUDGET=4000
RAG_BUDGET=6000
CRITIQUE_BUDGET=4000
SYNTHESIS_BUDGET=5000
COMPRESSION_BUDGET=2000
ORCHESTRATOR_BUDGET=3000
