# ─── LLM Provider ────────────────────────────────────────────────────────────
# Google Gemini (Primary LLM & Embeddings)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────────────
POSTGRES_HOST=aws-0-eu-central-1.pooler.supabase.com
POSTGRES_PORT=6543
POSTGRES_DB=postgres
POSTGRES_USER=postgres.xxxxxxxxxxxxxxxx
POSTGRES_PASSWORD=your_supabase_password

# Or just provide the full URL
DATABASE_URL=postgresql://postgres.hikcnmqvxnoqchbqyhrj:X7C4e9aD'Pri'#V@aws-1-ap-south-1.pooler.supabase.com:6543/postgres

# ─── Redis (Upstash Serverless Redis) ─────────────────────────────────────────
REDIS_URL=rediss://default:your_upstash_password@your-upstash-endpoint.upstash.io:32414
CELERY_BROKER_URL=rediss://default:your_upstash_password@your-upstash-endpoint.upstash.io:32414
CELERY_RESULT_BACKEND=rediss://default:your_upstash_password@your-upstash-endpoint.upstash.io:32414

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/chroma_data
CHROMA_COLLECTION_NAME=mega_ai_corpus

# ─── Log UI ───────────────────────────────────────────────────────────────────
LOG_UI_HOST=0.0.0.0
LOG_UI_PORT=8080

# ─── Evaluation ───────────────────────────────────────────────────────────────
# Set to "true" to auto-trigger eval after each pipeline run (dev only)
AUTO_EVAL=false

# ─── Context Budget Defaults (tokens) ────────────────────────────────────────
DECOMPOSITION_BUDGET=4000
RAG_BUDGET=6000
CRITIQUE_BUDGET=4000
SYNTHESIS_BUDGET=5000
COMPRESSION_BUDGET=2000
ORCHESTRATOR_BUDGET=3000
